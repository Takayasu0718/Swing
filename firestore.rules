rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ユーザープロフィール: 認証済みなら誰でも read 可能（検索のため）
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // activities: ランキング集計のため認証済みなら誰でも read 可能（書き込みは本人のみ）
    match /users/{userId}/activities/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // 他のサブコレクション（swings, missions など）は本人のみ
    match /users/{userId}/{collection}/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // フレンド関係: 当事者2人だけが read/write 可能
    match /friendships/{friendshipId} {
      allow read: if request.auth != null
                  && request.auth.uid in resource.data.participants;
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.fromUid
                    && request.resource.data.fromUid != request.resource.data.toUid
                    && request.auth.uid in request.resource.data.participants;
      allow update, delete: if request.auth != null
                            && request.auth.uid in resource.data.participants;
    }

    // チーム: 認証済みなら read 可能（検索のため）。
    // create は作成者本人がキャプテン兼初期メンバーであることが条件。
    // update / delete はメンバーまたはキャプテン。
    match /teams/{teamId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.captainId
                    && request.auth.uid in request.resource.data.memberIds;
      allow update: if request.auth != null
                    && (request.auth.uid in resource.data.memberIds
                        || request.auth.uid == resource.data.captainId);
      allow delete: if request.auth != null
                    && request.auth.uid == resource.data.captainId;
    }

    // チーム関連リクエスト（加入申請 / フレンドチーム申請）
    // 申請者本人と、対象チームのキャプテンが操作可能。
    match /teamRequests/{requestId} {
      allow read: if request.auth != null
                  && (request.auth.uid == resource.data.fromUid
                      || request.auth.uid == get(/databases/$(database)/documents/teams/$(resource.data.teamId)).data.captainId);
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.fromUid;
      allow update, delete: if request.auth != null
                            && (request.auth.uid == resource.data.fromUid
                                || request.auth.uid == get(/databases/$(database)/documents/teams/$(resource.data.teamId)).data.captainId);
    }
  }
}
