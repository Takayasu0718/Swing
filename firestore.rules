rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ユーザープロフィール: 認証済みなら誰でも read 可能（検索のため）
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ユーザーID（@ハンドル）の予約。ドキュメントID = userId.toLowerCase()。
    match /usernames/{userIdLower} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.ownerUid;
      allow update, delete: if request.auth != null
                            && request.auth.uid == resource.data.ownerUid;
    }

    // チームID（@ハンドル）の予約。ドキュメントID = handle.toLowerCase()。
    match /teamHandles/{handleLower} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.ownerUid;
      allow update, delete: if request.auth != null
                            && request.auth.uid == resource.data.ownerUid;
    }

    // activities: ランキング集計のため認証済みなら誰でも read 可能（書き込みは本人のみ）
    match /users/{userId}/activities/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // 他のサブコレクション（swings, missions など）は本人のみ
    match /users/{userId}/{collection}/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // フレンド関係: 当事者2人だけが read/write 可能
    match /friendships/{friendshipId} {
      allow read: if request.auth != null
                  && request.auth.uid in resource.data.participants;
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.fromUid
                    && request.resource.data.fromUid != request.resource.data.toUid
                    && request.auth.uid in request.resource.data.participants;
      allow update, delete: if request.auth != null
                            && request.auth.uid in resource.data.participants;
    }

    // チーム: 認証済みなら read 可能（検索のため）。
    // create は作成者本人がキャプテン兼初期メンバーであることが条件。
    // update / delete はメンバーまたはキャプテン。
    match /teams/{teamId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.captainId
                    && request.auth.uid in request.resource.data.memberIds;
      allow update: if request.auth != null
                    && (request.auth.uid in resource.data.memberIds
                        || request.auth.uid == resource.data.captainId);
      allow delete: if request.auth != null
                    && request.auth.uid == resource.data.captainId;

      // チームチャット: メンバーのみ read/write 可能。
      match /messages/{messageId} {
        allow read: if request.auth != null
                    && request.auth.uid in get(/databases/$(database)/documents/teams/$(teamId)).data.memberIds;
        allow create: if request.auth != null
                      && request.auth.uid == request.resource.data.userId
                      && request.auth.uid in get(/databases/$(database)/documents/teams/$(teamId)).data.memberIds;
        allow update: if request.auth != null
                      && request.auth.uid in get(/databases/$(database)/documents/teams/$(teamId)).data.memberIds;
        allow delete: if request.auth != null
                      && request.auth.uid == resource.data.userId;
      }
    }

    // チーム関連リクエスト（加入申請 / フレンドチーム申請）
    // 申請者本人と、対象チームのキャプテンが操作可能。
    // 通知: 受信者(userId)のみ read/update/delete 可能。
    // 作成者は自身の uid でしか fromUserId にできない（なりすまし防止）。
    // タイムライン用アクティビティ。誰でも read 可能、
    // 投稿は本人のみ、いいね（likeUserIds のみの差分）は誰でも更新可能。
    match /activities/{actId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.userId;
      allow update: if request.auth != null
                    && (
                      request.auth.uid == resource.data.userId
                      || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likeUserIds'])
                    );
      allow delete: if request.auth != null
                    && request.auth.uid == resource.data.userId;
    }

    match /notifications/{notifId} {
      allow read: if request.auth != null
                  && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.fromUserId;
      allow update: if request.auth != null
                    && request.auth.uid == resource.data.userId;
      allow delete: if request.auth != null
                    && request.auth.uid == resource.data.userId;
    }

    // 体験会・試合助っ人参加のお願い: 1チーム1件（teamId=docId）。
    // 読み取り・書き込みともにチームメンバー全員可。
    match /trialRequests/{teamId} {
      allow read: if request.auth != null
                  && request.auth.uid in get(/databases/$(database)/documents/teams/$(teamId)).data.memberIds;
      allow create, update, delete: if request.auth != null
                    && request.auth.uid in get(/databases/$(database)/documents/teams/$(teamId)).data.memberIds;

      // 参加状態: docId == 自分の uid のもののみ書ける。
      match /participants/{uid} {
        allow read: if request.auth != null
                    && request.auth.uid in get(/databases/$(database)/documents/teams/$(teamId)).data.memberIds;
        allow create, update, delete: if request.auth != null
                      && request.auth.uid == uid;
      }
    }

    // 1対1 DM。dms/{convId} と messages サブコレクション。
    // convId = sorted([uidA, uidB]).join('_')。当事者2人だけが read/write 可能。
    match /dms/{convId} {
      allow read: if request.auth != null
                  && request.auth.uid in resource.data.participants;
      allow create: if request.auth != null
                    && request.auth.uid in request.resource.data.participants
                    && request.resource.data.participants.size() == 2;
      allow update: if request.auth != null
                    && request.auth.uid in resource.data.participants;
      allow delete: if false;

      match /messages/{msgId} {
        allow read: if request.auth != null
                    && request.auth.uid in get(/databases/$(database)/documents/dms/$(convId)).data.participants;
        allow create: if request.auth != null
                      && request.auth.uid == request.resource.data.senderUid
                      && request.auth.uid in get(/databases/$(database)/documents/dms/$(convId)).data.participants;
        allow update, delete: if request.auth != null
                              && request.auth.uid == resource.data.senderUid;
      }
    }

    // 開発中は認証済みなら read/write を許可（後で厳格化予定）。
    // 厳格版はクエリに where('fromUid', '==', auth.uid) など必須。
    match /teamRequests/{requestId} {
      allow read, write: if request.auth != null;
    }
  }
}
