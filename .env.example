# Copy to .env.local and fill in values from your Firebase console.
# .env.local is gitignored automatically by Vite (*.local pattern).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# デモデータ（モックフレンド/チーム/通知）を生成するか。
# 未設定または true: 生成（開発・1人デモ向け）
# false:             生成しない（本番マルチユーザー向け）
VITE_SEED_DEMO_DATA=true
